{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"entry": ["src/app/**/*.{ts,tsx}"],
	"project": ["src/**/*.{ts,tsx}"],
	"ignore": ["src/components/ui/**"],
	"ignoreDependencies": [
		"@base-ui/react",
		"@testing-library/react",
		"class-variance-authority",
		"lucide-react",
		"postcss",
		"shadcn",
		"tailwindcss",
		"tw-animate-css",
		"zod"
	],
	"ignoreBinaries": ["drizzle-kit"],
	"next": {
		"entry": ["src/app/**/*.{ts,tsx}", "next.config.ts"]
	}
}
